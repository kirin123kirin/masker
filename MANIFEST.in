# sdist に含めるファイル
include LICENSE
include README.md
include pyproject.toml

# カスタム辞書テンプレート
recursive-include src/pymasking/dict *.txt

# 除外（PyPI パッケージには含めない）
prune app
prune launchers
prune tests
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *.so
global-exclude .DS_Store
exclude test_*.py
exclude *_test.py
